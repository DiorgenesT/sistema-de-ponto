# =============================================================================
# .env.example — commitar este arquivo. NUNCA commitar o .env real.
# Copie para .env e preencha os valores antes de rodar o projeto.
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=           # service role key — NUNCA expor no frontend
SUPABASE_ANON_KEY=              # anon key — pode ir no frontend / Workers

# --- Banco (direto via SQLAlchemy no backend) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- Auth JWT ---
JWT_SECRET_KEY=                 # mínimo 64 chars — gerar: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Biometria (LGPD) ---
FACIAL_ENCRYPTION_KEY=          # AES-256 base64 de 32 bytes — gerar: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
FACIAL_SIMILARITY_THRESHOLD=0.75

# --- NTP (exigência Portaria 671) ---
NTP_SERVER=a.ntp.br

# --- Redis (Celery + cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Monitoramento ---
SENTRY_DSN=

# --- App ---
ENVIRONMENT=development         # development | staging | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8788,https://ponto.empresa.com.br

# --- Cloudflare (frontend Workers) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
